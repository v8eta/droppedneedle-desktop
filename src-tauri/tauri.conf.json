{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "DroppedNeedle Desktop",
	"version": "../package.json",
	"identifier": "dev.v8eta.droppedneedle-desktop",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "DroppedNeedle",
				"width": 1280,
				"height": 800,
				"minWidth": 960,
				"minHeight": 640,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' http://dn.localhost data: blob:; media-src 'self' http://dn.localhost blob:; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:"
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
